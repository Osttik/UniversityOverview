<Window x:Class="UniversityProgramm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="University Overview"
        Height="720"
        MinHeight="640"
        Width="1120"
        MinWidth="960"
        Background="#F5F7FA">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1E3A8A" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE4EE" />

        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="FilterComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <DataTemplate x:Key="UniversityCardTemplate">
            <Border Margin="0,0,0,10"
                    Padding="16"
                    Background="#FFFFFF"
                    BorderBrush="#DDE4EE"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Name}"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1"
                               Margin="0,6,0,0"
                               Text="{Binding LocationDisplay}"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                    <StackPanel Grid.Row="2"
                                Margin="0,12,0,0"
                                Orientation="Horizontal">
                        <Border Padding="8,4"
                                Background="#DBEAFE"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1">
                            <TextBlock Text="{Binding DegreeFocus}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryDarkBrush}" />
                        </Border>
                        <TextBlock Margin="12,4,0,0"
                                   Text="{Binding TuitionSummary}"
                                   FontSize="12"
                                   Foreground="#475569" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F172A"
                Padding="28,22">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Content="Exit"
                        Width="92"
                        Click="Exit"
                        Style="{StaticResource ActionButton}" />
                <StackPanel>
                    <TextBlock Text="Public University Catalog"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock x:Name="SummaryText"
                               Margin="0,7,0,0"
                               FontSize="14"
                               Foreground="#CBD5E1"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Find a university"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <TextBox x:Name="SearchBox"
                                 Margin="0,14,0,0"
                                 Style="{StaticResource FilterTextBox}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Search by name, country, city, program, or focus area" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,14,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CountryFilter"
                                  Grid.Column="0"
                                  Style="{StaticResource FilterComboBox}"
                                  SelectionChanged="Filter_SelectionChanged" />
                        <ComboBox x:Name="ProgramFilter"
                                  Grid.Column="2"
                                  Style="{StaticResource FilterComboBox}"
                                  SelectionChanged="Filter_SelectionChanged" />
                    </Grid>

                    <ListBox x:Name="CatalogList"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemTemplate="{StaticResource UniversityCardTemplate}"
                             SelectionChanged="CatalogList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="SelectedNameText"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="SelectedLocationText"
                                   Margin="0,8,0,0"
                                   FontSize="15"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1"
                                 Margin="0,28,0,24"
                                 Columns="4">
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                BorderBrush="#DDE4EE"
                                BorderThickness="1"
                                Background="#F8FAFC">
                            <StackPanel>
                                <TextBlock Text="Established" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="EstablishedText" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                BorderBrush="#DDE4EE"
                                BorderThickness="1"
                                Background="#F8FAFC">
                            <StackPanel>
                                <TextBlock Text="Students" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="StudentsText" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0"
                                Padding="14"
                                BorderBrush="#DDE4EE"
                                BorderThickness="1"
                                Background="#F8FAFC">
                            <StackPanel>
                                <TextBlock Text="Acceptance" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="AcceptanceText" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="14"
                                BorderBrush="#DDE4EE"
                                BorderThickness="1"
                                Background="#F8FAFC">
                            <StackPanel>
                                <TextBlock Text="Annual tuition" Style="{StaticResource MetricLabel}" />
                                <TextBlock x:Name="TuitionText" Style="{StaticResource MetricValue}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Grid.Row="2"
                               x:Name="SelectedDescriptionText"
                               FontSize="15"
                               LineHeight="24"
                               Foreground="#334155"
                               TextWrapping="Wrap" />

                    <Grid Grid.Row="3" Margin="0,28,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Popular Programs"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="#0F172A" />
                            <ItemsControl x:Name="ProgramsList" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,8"
                                                Background="#EEF2FF"
                                                BorderBrush="#C7D2FE"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#312E81"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Campus Highlights"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="#0F172A" />
                            <ItemsControl x:Name="HighlightsList" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,10"
                                                   Text="{Binding}"
                                                   FontSize="14"
                                                   Foreground="#475569"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button x:Name="WebsiteButton"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Left"
                                    MinWidth="150"
                                    Content="Open website"
                                    Style="{StaticResource ActionButton}"
                                    Click="WebsiteButton_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
