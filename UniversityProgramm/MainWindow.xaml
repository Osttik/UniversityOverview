<Window x:Class="UniversityProgramm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UniversityProgramm.Helpers"
        mc:Ignorable="d"
        Title="University Overview"
        Height="720"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="#F3F5F8">
    <Window.DataContext>
        <local:ApplicationModel />
    </Window.DataContext>

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5F6B7A" />
        <SolidColorBrush x:Key="TextBrush" Color="#17202A" />
        <SolidColorBrush x:Key="AccentBrush" Color="#176B87" />

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="UniversityListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="#F7F9FB"
                                BorderBrush="#DFE6EE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#8BB8C7" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF7FA" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E7F4F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="22" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#DEE4EA"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Universities"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Search by university, city, faculty, or program"
                               Margin="0,4,0,14"
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="36"
                             Padding="10,7"
                             BorderBrush="#CAD4DD"
                             BorderThickness="1"
                             FontSize="14" />
                </StackPanel>

                <ListBox ItemsSource="{Binding UniversitiesView}"
                         SelectedItem="{Binding SelectedUniversity, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource UniversityListItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,16,0,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Location}"
                                           Margin="0,5,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding FacultyCount}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text=" faculties" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="  |  " Foreground="#A8B1BB" />
                                    <TextBlock Text="{Binding ProgramCount}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text=" programs" Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#DEE4EA"
                BorderThickness="1"
                CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="24">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedUniversity}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#EFF7FA"
                            BorderBrush="#C8E0E8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{Binding SelectedUniversity.Name}"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedUniversity.Location}"
                                           Margin="0,6,0,0"
                                           FontSize="16"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="{Binding SelectedUniversity.Overview}"
                                           Margin="0,16,30,0"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="15"
                                           LineHeight="22"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <UniformGrid Grid.Column="1" Columns="1" Rows="3">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Founded" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding SelectedUniversity.Founded}" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Students" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding SelectedUniversity.Students}" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Website" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding SelectedUniversity.Website}" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#F7F9FB"
                                BorderBrush="#E2E8EF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Campus"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding SelectedUniversity.Campus}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           LineHeight="21"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="#F7F9FB"
                                BorderBrush="#E2E8EF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Accreditation"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding SelectedUniversity.Accreditation}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedBrush}"
                                           LineHeight="21"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Faculties and Programs"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,12" />

                        <ItemsControl ItemsSource="{Binding SelectedUniversity.Faculties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="True" Margin="0,0,0,12">
                                        <Expander.Header>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextWrapping="Wrap" />
                                                <Border Grid.Column="1"
                                                        Background="#E7F4F7"
                                                        BorderBrush="#C8E0E8"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="9,3"
                                                        Margin="14,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ProgramCount}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                        <TextBlock Text=" programs" Foreground="{StaticResource AccentBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Expander.Header>

                                        <Border Background="#F7F9FB"
                                                BorderBrush="#E2E8EF"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="16"
                                                Margin="0,8,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Summary}"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap"
                                                           LineHeight="21" />
                                                <TextBlock Margin="0,8,0,12"
                                                           Foreground="{StaticResource MutedBrush}">
                                                    <Run Text="Dean: " />
                                                    <Run Text="{Binding Dean}" FontWeight="SemiBold" />
                                                </TextBlock>

                                                <ItemsControl ItemsSource="{Binding Programs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FFFFFF"
                                                                    BorderBrush="#E4EAF0"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="14"
                                                                    Margin="0,0,0,10">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="200" />
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontSize="16"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource TextBrush}"
                                                                                   TextWrapping="Wrap" />
                                                                        <TextBlock Text="{Binding Summary}"
                                                                                   Margin="0,7,20,0"
                                                                                   Foreground="{StaticResource MutedBrush}"
                                                                                   LineHeight="20"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding Degree}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                                        <TextBlock Text="{Binding Duration}" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}" />
                                                                        <TextBlock Text="{Binding Language}" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                                                        <TextBlock Text="{Binding Tuition}" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
