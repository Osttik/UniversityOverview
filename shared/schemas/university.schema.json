{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://university-overview.local/schemas/university.schema.json",
  "title": "University",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "shortName",
    "country",
    "city",
    "website",
    "foundedYear",
    "campusIds",
    "facultyIds",
    "programIds"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "shortName": {
      "type": "string",
      "minLength": 1
    },
    "country": {
      "type": "string",
      "minLength": 1
    },
    "city": {
      "type": "string",
      "minLength": 1
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "foundedYear": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 2100
    },
    "campusIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "facultyIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "programIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
