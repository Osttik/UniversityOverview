{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://university-overview.local/schemas/faculty.schema.json",
  "title": "Faculty",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "universityId",
    "name",
    "shortName",
    "description",
    "programIds"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "universityId": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "shortName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "programIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
