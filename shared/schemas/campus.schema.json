{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://university-overview.local/schemas/campus.schema.json",
  "title": "Campus",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "universityId",
    "name",
    "address",
    "coordinates",
    "facilities"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "universityId": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "address": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "line1",
        "city",
        "country",
        "postalCode"
      ],
      "properties": {
        "line1": {
          "type": "string",
          "minLength": 1
        },
        "city": {
          "type": "string",
          "minLength": 1
        },
        "country": {
          "type": "string",
          "minLength": 1
        },
        "postalCode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latitude",
        "longitude"
      ],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "facilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    }
  }
}
